<mujoco model="scene">
    <include file="so101_new_calib.xml" />

    <!-- Lighting -->
    <visual>
        <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0" />
        <rgba haze="0.15 0.25 0.35 1" />
        <global azimuth="160" elevation="-20" />
    </visual>

    <!-- World Environment -->
    <asset>
        <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072" />
        <texture type="2d" name="table_tex" builtin="checker" mark="edge" rgb1="0.8 0.8 0.8" rgb2="0.7 0.7 0.7" markrgb="0.5 0.5 0.5" width="300" height="300" />
        <material name="table_mat" texture="table_tex" texuniform="true" texrepeat="5 5" reflectance="0.1" />
    </asset>


    <worldbody>
        <light pos="0 0 3.5" dir="0 0 -1" directional="true" />
        
        <geom name="table" size="0.5 0.5 0.05" pos="0.25 0 -0.05" type="box" material="table_mat" />

        <!-- Used for Teleoperation -->
        <body name="mocap_target" mocap="true" pos="0.2 0 0.1">
            <geom type="box" size="0.01 0.01 0.01" rgba="1 0 1 0" contype="0" conaffinity="0" />
        </body>

        <!-- Intel D435, placed high and angled down -->
        <camera name="workspace_cam" pos="0.6 0 0.5" euler="0 0.8 3.1415" fovy="69" />

        <!-- Bins -->
        <body name="left-bin" pos="-0.2 0.7 0.001">
            <!-- four thin walls + a floor -->
            <geom name="bin_wall" type="box" size="0.06 0.005 0.03" pos=" 0.00  0.06 0.03" />
            <geom name="bin_wall2" type="box" size="0.06 0.005 0.03" pos=" 0.00 -0.06 0.03" />
            <geom name="bin_wall3" type="box" size="0.005 0.06 0.03" pos=" 0.06  0.00 0.03" />
            <geom name="bin_wall4" type="box" size="0.005 0.06 0.03" pos="-0.06  0.00 0.03" />
            <geom name="bin_floor" type="box" size="0.06 0.06 0.005" pos="0 0 -0.005" />
            <site name="left_bin_center" pos="0 0 0.02" />
        </body>
        
        <!-- <body name="right_bin" pos="0.3 -0.2 0">
            <geom type="box" size="0.06 0.06 0.002" pos="0 0 0.002" rgba="0 0 1 0.3" contype="0" conaffinity="0"/>
            <site name="right_bin_dropzone" pos="0 0 0.02" size="0.02" rgba="0 1 0 0"/>
        </body> -->

        <!-- Blocks -->
        <body name="red_box" pos="0.3 0 0.05">
            <joint name="red_block_joint" type="free" frictionloss="0.01" />
            <inertial pos="0 0 0" mass="0.05" diaginertia="0.002 0.002 0.002" />
            <geom condim="4" solimp="2 1 0.01" solref="0.01 1" friction="1 0.005 0.0001" pos="0 0 0"
                size="0.02 0.02 0.02" type="box" name="red_block" rgba="1 0 0 1" />
            <site name="red_block_site" pos="0.01 0.01 0.01" />
        </body>

        <!-- <body name="blue_block" pos="0.2 0.1 0.05">
            <freejoint/>
            <geom name="blue_block_geom" type="box" size="0.015 0.015 0.015" rgba="0 0 1 1" mass="0.02" friction="2 0.05 0.0001"/>
            <site name="blue_block_center" pos="0 0 0" size="0.01" rgba="0 0 1 0"/>

        </body> -->

    </worldbody>

     <keyframe>
        <key name="home" qpos="0 -1.57 1.57 1.57 -1.57 0.  0.2 0.5 0.05 1 0 0 0"
            ctrl="0 -1.57 1.57 1.57 -1.57 0" />
        <key name="rest" qpos="0 -3.32 3.11 1.18 0 -0.174   0.2 0.5 0.05 1 0 0 0"
            ctrl="0 -3.32 3.11 1.18 0 -0.174" />
    </keyframe>
    
</mujoco>